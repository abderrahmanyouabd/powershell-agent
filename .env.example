# GROQ_API_KEY: required - get one free at https://console.groq.com/keys
GROQ_API_KEY=your-api-key-here

# MODEL_PS: model for the main agent loop (default shown below)
# Supported: llama-3.3-70b-versatile, llama-3.1-8b-instant, qwen/qwen3-32b, openai/gpt-oss-120b
# Note: if using --github (MCP), only the models listed above work. mixtral and gemma are NOT supported.
MODEL_PS=llama-3.3-70b-versatile

# GITHUB_TOKEN: GitHub personal access token (classic, repo scope)
# Required for private repos with --github. Public repos work without it.
# Get one at: https://github.com/settings/tokens
GITHUB_TOKEN=

# PS_TIMEOUT: PowerShell command timeout in seconds (default 300)
PS_TIMEOUT=300

# PS_MAX_ITERATIONS: max agent loop iterations (default 10)
PS_MAX_ITERATIONS=10

# PS_HISTORY_DIR: where sessions are saved (default ~/.powershell-agent/history)
# PS_HISTORY_DIR=C:\Users\you\.powershell-agent\history
